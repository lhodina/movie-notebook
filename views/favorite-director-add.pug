extends layout.pug
include utils.pug
block content
    link(rel='stylesheet' href='/stylesheets/add-form.css')
    +handleErrors(errors)
    h2 Add Favorite Director
    main
        div(class="form-container")
            form(action="/favorite-directors/add", method="post")
                input(type="hidden" name="_csrf" value=csrfToken)
                label(for="director") Choose or Add a Director
                br
                input(name="directorName" list="directors")
                datalist(id="directors" name="directors")
                    each director in directors
                        option(value=director.name)
                br
                label(for="notes") Notes
                br
                textarea(name="notes")
                br
                +field("Link Text", "linkText")
                +field("Link URL", "linkUrl")
                br
                button(type="submit") Add
