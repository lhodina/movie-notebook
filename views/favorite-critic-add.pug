extends layout.pug
include utils.pug
block content
    link(rel='stylesheet' href='/stylesheets/add-form.css')
    +handleErrors(errors)
    h2 Add Favorite Critic
    main
        div(class="form-container")
            form(action="/favorite-critics/add", method="post")
                input(type="hidden" name="_csrf" value=csrfToken)
                label(for="critic") Choose or Add a Critic
                input(name="name" list="critics")
                datalist(id="critics" name="critics")
                    each critic in critics
                        option(value=critic.name)
                br
                label(for="notes") Notes
                textarea(name="notes")
                br
                button(type="submit") Submit
