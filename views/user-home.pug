extends layout.pug
block content
    script(src="/scripts/index.js" type="module")
    h2 User Home
    h3 Collections
    each collection in collections
        div
            a(href=`/collections/${collection.id}`)= collection.name
            table
                thead
                    tr
                        th Title
                        th Director
                        th Year Released
                        th Image
                        th Review
                        th Rating
                        th Status
                        th

                tbody
                    each movie in collection.movies
                        tr
                            td
                                a(href=`/movies/${movie.id}`) #{movie.title}
                            td= movie.director
                            td= movie.yearReleased
                            if movie.imageLink
                                td
                                    img(src=movie.imageLink width=60 height=90)
                            else
                                td Add Image
                            td= movie.review
                            td= movie.rating
                            td= movie.watchedStatus
                            td
                                a(href=`/movies/${movie.id}`) edit
            br
            br

    h3 Your Favorite Directors
    ul
        each favoriteDirector in favoriteDirectors
            li= favoriteDirector.name

    h3 Your Favorite Critics
    ul
        each favoriteCritic in favoriteCritics
            li= favoriteCritic.name
