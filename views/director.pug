extends layout.pug
include utils.pug
block content
    h2= director.name
    h3 Add a Favorite Movie
    form(action=`/directors/${director.id}/favorites/add` method="post")
        input(type="hidden" name="_csrf" value=csrfToken)
        +addMovieFormFields()
        button(type="submit") Add Favorite
        a(href=`directors/${director.id}`) Cancel

    h3 Movies Directed by #{director.name}
    if (directedMovies)
        +displayMovies(directedMovies)
    h3 #{director.name}'s Favorite Movies
    if (favoriteMovies)
        +displayMovies(favoriteMovies)
